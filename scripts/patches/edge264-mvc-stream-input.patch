+#!/usr/bin/env python3
+"""Compare edge264_test regular-file, stdin, and FIFO streaming output.
+
+The fixtures are tiny MVC bitstreams committed under tests/conformance. The
+checker intentionally writes the FIFO in very small chunks so 00 00 01 start
+codes are split across reads, and every subprocess has a timeout so stream input
+regressions fail as deadlocks instead of hanging `make check-stream-input`.
+"""
+
+import argparse
+import os
+import subprocess
+import sys
+import tempfile
+import threading
+import time
+from pathlib import Path
+from typing import List, Optional
+
+
+CHUNK_PATTERN = (1, 2, 1, 3, 5, 8, 13, 2, 4, 7, 11, 17)
+
+
+def run_regular(exe: Path, fixture: Path, mode: str, timeout: float) -> bytes:
+    return run_capture([str(exe), str(fixture), mode, "-k", "-y"], None, timeout, fixture.name, f"regular {mode}")
+
+
+def run_stdin(exe: Path, fixture: Path, mode: str, timeout: float) -> bytes:
+    data = fixture.read_bytes()
+    return run_capture([str(exe), "-", mode, "-k", "-y"], data, timeout, fixture.name, f"stdin {mode}")
+
+
+def run_capture(argv: List[str], stdin: Optional[bytes], timeout: float, fixture: str, mode: str) -> bytes:
+    try:
+        completed = subprocess.run(argv, input=stdin, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=timeout, check=False)
+    except subprocess.TimeoutExpired as exc:
+        raise RuntimeError(f"{fixture}: {mode} timed out after {timeout:g}s") from exc
+    if completed.returncode != 0:
+        raise RuntimeError(
+            f"{fixture}: {mode} exited {completed.returncode}\n"
+            f"stderr:\n{completed.stderr.decode(errors='replace')}"
+        )
+    if not completed.stdout.startswith(b"YUV4MPEG2"):
+        raise RuntimeError(f"{fixture}: {mode} did not produce a Y4M stream")
+    return completed.stdout
+
+
+def run_fifo(exe: Path, fixture: Path, mode: str, timeout: float) -> bytes:
+    with tempfile.TemporaryDirectory(prefix="edge264-stream-input-") as td:
+        fifo = Path(td) / f"{fixture.stem}.264"
+        os.mkfifo(fifo)
+        proc = subprocess.Popen(
+            [str(exe), str(fifo), mode, "-k", "-y"],
+            stdout=subprocess.PIPE,
+            stderr=subprocess.PIPE,
+        )
+        writer_error: List[BaseException] = []
+
+        def writer() -> None:
+            try:
+                data = fixture.read_bytes()
+                with fifo.open("wb", buffering=0) as pipe:
+                    pos = 0
+                    i = 0
+                    while pos < len(data):
+                        n = CHUNK_PATTERN[i % len(CHUNK_PATTERN)]
+                        pipe.write(data[pos : pos + n])
+                        pos += n
+                        i += 1
+                        if i % 19 == 0:
+                            time.sleep(0.001)
+            except BaseException as exc:  # communicate thread failures to main
+                writer_error.append(exc)
+
+        thread = threading.Thread(target=writer, name=f"fifo-writer-{fixture.stem}", daemon=True)
+        thread.start()
+        try:
+            stdout, stderr = proc.communicate(timeout=timeout)
+        except subprocess.TimeoutExpired as exc:
+            proc.kill()
+            stdout, stderr = proc.communicate()
+            thread.join(timeout=1)
+            raise RuntimeError(
+                f"{fixture.name}: fifo timed out after {timeout:g}s\n"
+                f"partial stdout={len(stdout)} bytes\n"
+                f"stderr:\n{stderr.decode(errors='replace')}"
+            ) from exc
+        thread.join(timeout=timeout)
+        if thread.is_alive():
+            raise RuntimeError(f"{fixture.name}: fifo writer did not finish")
+        if writer_error:
+            raise RuntimeError(f"{fixture.name}: fifo writer failed: {writer_error[0]!r}")
+        if proc.returncode != 0:
+            raise RuntimeError(
+                f"{fixture.name}: fifo exited {proc.returncode}\n"
+                f"stderr:\n{stderr.decode(errors='replace')}"
+            )
+        if not stdout.startswith(b"YUV4MPEG2"):
+            raise RuntimeError(f"{fixture.name}: fifo did not produce a Y4M stream")
+        return stdout
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--exe", default="./edge264_test", type=Path)
+    parser.add_argument("--timeout", default=10.0, type=float)
+    parser.add_argument(
+        "fixtures",
+        nargs="*",
+        type=Path,
+        default=[
+            Path("tests/conformance/mvc-synthetic/mvc_same_poc_pairing.264"),
+            Path("tests/conformance/mvc-synthetic/mvc_dependent_frame_num_gap.264"),
+            Path("tests/conformance/mvc-synthetic/mvc_late_dependent.264"),
+        ],
+    )
+    args = parser.parse_args()
+
+    exe = args.exe.resolve()
+    for fixture in args.fixtures:
+        fixture = fixture.resolve()
+        for mode in ("-o", "-O"):
+            regular = run_regular(exe, fixture, mode, args.timeout)
+            stdin = run_stdin(exe, fixture, mode, args.timeout)
+            fifo = run_fifo(exe, fixture, mode, args.timeout)
+            if stdin != regular:
+                raise RuntimeError(f"{fixture.name} {mode}: stdin Y4M differs from regular-file output")
+            if fifo != regular:
+                raise RuntimeError(f"{fixture.name} {mode}: FIFO Y4M differs from regular-file output")
+            print(f"PASS {fixture.name} {mode}: {len(regular)} bytes")
+    return 0
+
+
+if __name__ == "__main__":
+    try:
+        raise SystemExit(main())
+    except RuntimeError as exc:
+        print(f"FAIL {exc}", file=sys.stderr)
+        raise SystemExit(1)
