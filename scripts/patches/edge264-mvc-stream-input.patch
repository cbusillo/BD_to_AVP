+static int drain_frames(int *res, int *quit)
+{
+	int drained = 0;
+	while (!edge264_get_frame(d, &out, 0)) {
+		drained++;
+		if (dump)
+			dump_frame();
+		if (conf[0] != NULL && check_frame()) {
+			*res = EBADMSG;
+			break;
+		} else if (display && draw_frame()) {
+			*res = ENODATA;
+			*quit = 1;
+			break;
+		}
+	}
+	return drained;
+}
+
+static int decode_nal_and_drain(const uint8_t *nal, const uint8_t *end, int *stuck, int *quit)
+{
+	int res = edge264_decode_NAL(d, nal, end, NULL, NULL);
+	int drained = drain_frames(&res, quit);
+	// Never abandon a NAL the decoder asked us to retry. Fail explicitly after a
+	// bounded no-progress streak instead of spinning forever or silently
+	// truncating the stream.
+	*stuck = (res == ENOBUFS && drained == 0) ? *stuck + 1 : 0;
+	if (*stuck > 64) {
+		fprintf(msg, "Decoder made no progress after repeated ENOBUFS responses\n");
+		moveup = "";
+		res = EBADMSG;
+	}
+	return res;
+}
+
+static int keep_decoding(int res)
+{
+	// -k: mirror a real player's decode loop by skipping an unsupported NAL
+	// (ENOTSUP) and continuing, instead of stopping at the first one. Real 3D
+	// Blu-rays carry per-access-unit unspecified NALs (type 24) that edge264
+	// reports ENOTSUP by design; without this the tool halts at the first one and
+	// never reaches the dependent view.
+	return res == 0 || res == ENOBUFS || (res == ENOTSUP && skip_unsupported);
+}
+
+static int finish_decode_result(int res, const uint8_t *end1)
+{
+	edge264_flush(d);
+	if (res == ENOBUFS || (res == ENODATA && conf[0] != NULL && conf[0] != end1))
+		res = EBADMSG;
+	return res;
+}
+
+static int decode_mapped_input(const uint8_t *buf, const uint8_t *end0, const uint8_t *end1, int *quit)
+{
+	if (end0 - buf < 3)
+		return finish_decode_result(EBADMSG, end1);
+	const uint8_t *start = edge264_find_start_code(buf, end0, 0);
+	if (start == end0)
+		return finish_decode_result(EBADMSG, end1);
+	const uint8_t *nal = start + 3 + (start[2] == 0); // skip the [0]001 delimiter
+	int res, stuck = 0;
+	y4m_started = 0; // one Y4M stream header per file
+	do {
+		const uint8_t *end = edge264_find_start_code(nal, end0, 0);
+		res = decode_nal_and_drain(nal, end, &stuck, quit);
+		if (res != ENOBUFS)
+			nal = end + 3;
+	} while (keep_decoding(res));
+	return finish_decode_result(res, end1);
+}
+
+#define STREAM_CHUNK 4096
+#define STREAM_MAX_NAL_SIZE (64 * 1024 * 1024)
+#define STREAM_PAD 32
+
+typedef struct StreamBuffer {
+	uint8_t *alloc;
+	uint8_t *data;
+	size_t len;
+	size_t cap;
+	FILE *file;
+	const char *name;
+	int eof;
+} StreamBuffer;
+
+static int stream_reserve(StreamBuffer *s, size_t need)
+{
+	if (need <= s->cap)
+		return 0;
+	size_t cap = s->cap ? s->cap : STREAM_CHUNK;
+	while (cap < need) {
+		if (cap > SIZE_MAX / 2) {
+			errno = ENOMEM;
+			perror(s->name);
+			return -1;
+		}
+		cap *= 2;
+	}
+	uint8_t *alloc = malloc(cap + 2 * STREAM_PAD + 15);
+	if (alloc == NULL) {
+		perror(s->name);
+		return -1;
+	}
+	uint8_t *data = (uint8_t *)(((uintptr_t)alloc + STREAM_PAD + 15) & ~(uintptr_t)15);
+	if (s->data != NULL)
+		memcpy(data, s->data, s->len);
+	free(s->alloc);
+	s->alloc = alloc;
+	s->data = data;
+	s->cap = cap;
+	memset(s->data + s->len, 0, STREAM_PAD);
+	return 0;
+}
+
+static void stream_discard(StreamBuffer *s, size_t n)
+{
+	if (n == 0)
+		return;
+	if (n < s->len)
+		memmove(s->data, s->data + n, s->len - n);
+	s->len -= n;
+	memset(s->data + s->len, 0, STREAM_PAD);
+}
+
+static int stream_read_more(StreamBuffer *s)
+{
+	if (s->eof)
+		return 0;
+	if (stream_reserve(s, s->len + STREAM_CHUNK) < 0)
+		return -1;
+	size_t n = fread(s->data + s->len, 1, STREAM_CHUNK, s->file);
+	if (n != 0) {
+		s->len += n;
+		memset(s->data + s->len, 0, STREAM_PAD);
+		return 0;
+	}
+	if (ferror(s->file)) {
+		perror(s->name);
+		return -1;
+	}
+	s->eof = 1;
+	return 0;
+}
+
+static int find_initial_start_code(StreamBuffer *s, size_t *nal_off)
+{
+	while (1) {
+		for (size_t i = 0; i + 2 < s->len; i++) {
+			if (s->data[i] == 0 && s->data[i + 1] == 0) {
+				if (s->data[i + 2] == 1) {
+					stream_discard(s, i);
+					*nal_off = 3;
+					return 0;
+				}
+				if (i + 3 < s->len && s->data[i + 2] == 0 && s->data[i + 3] == 1) {
+					stream_discard(s, i);
+					*nal_off = 4;
+					return 0;
+				}
+			}
+		}
+		if (s->eof) {
+			fprintf(msg, "%s: no H.264 start code found\n", s->name);
+			moveup = "";
+			return -1;
+		}
+		// Keep only the bytes that can still be the prefix of a split 4-byte start
+		// code. This avoids buffering an unbounded preamble from a pipe.
+		if (s->len > 3)
+			stream_discard(s, s->len - 3);
+		if (stream_read_more(s) < 0)
+			return -1;
+	}
+}
+
+static int decode_stream_input(FILE *file, const char *name, const uint8_t *end1, int *quit)
+{
+	StreamBuffer s = {.file = file, .name = name};
+	int res = EBADMSG;
+	int stuck = 0;
+	int final_consumed = 0;
+	size_t nal_off = 0;
+	y4m_started = 0; // one Y4M stream header per file
+	if (stream_read_more(&s) < 0 || find_initial_start_code(&s, &nal_off) < 0)
+		goto done;
+	do {
+		const uint8_t *nal, *end;
+		const uint8_t *next = NULL;
+		if (final_consumed) {
+			nal = end = s.data + s.len;
+		} else {
+			size_t search_off = nal_off;
+			while (1) {
+				if (nal_off > s.len) {
+					res = EBADMSG;
+					goto done;
+				}
+				nal = s.data + nal_off;
+				end = s.data + s.len;
+				if (search_off < nal_off)
+					search_off = nal_off;
+				next = edge264_find_start_code(s.data + search_off, end, 0);
+				if (next != end || s.eof)
+					break;
+				if (s.len >= STREAM_MAX_NAL_SIZE) {
+					fprintf(msg, "%s: NAL exceeds the %d MiB streaming limit\n", s.name, STREAM_MAX_NAL_SIZE / 1024 / 1024);
+					moveup = "";
+					res = EBADMSG;
+					goto done;
+				}
+				search_off = s.len > 3 ? s.len - 3 : nal_off;
+				if (stream_read_more(&s) < 0)
+					goto done;
+			}
+			end = next;
+		}
+		res = decode_nal_and_drain(nal, end, &stuck, quit);
+		if (!final_consumed) {
+			if (res != ENOBUFS) {
+				if (next != s.data + s.len) {
+					stream_discard(&s, (size_t)(next - s.data));
+					nal_off = 3;
+				} else {
+					final_consumed = 1;
+				}
+			}
+		}
+	} while (keep_decoding(res));
+done:
+	free(s.alloc);
+	return finish_decode_result(res, end1);
+}
