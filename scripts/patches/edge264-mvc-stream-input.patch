+# Native edge264_test stream-input regression. Compares regular-file mmap,
+# stdin (-), and FIFO/non-regular input Y4M output on small MVC fixtures, with
+# tiny FIFO writes that split start codes and subprocess timeouts for deadlocks.
+.PHONY: check-stream-input
+check-stream-input: edge264_test$(EXE)
+ifneq (,$(findstring $(OS),macos linux))
+	$(Q)$(PY) tests/stream_input_check.py --exe ./edge264_test$(EXE)
+endif
